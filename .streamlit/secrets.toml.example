# Copy this file to .streamlit/secrets.toml and replace the placeholder
# values below.
#
# DO NOT commit .streamlit/secrets.toml to Git. It is listed in .gitignore.
#
# When deploying to Streamlit Community Cloud, paste the same values into
# the Secrets section of the Community Cloud UI instead of using this file.


# === Required: your OpenAI API key ===
OPENAI_API_KEY = "sk-REPLACE-WITH-YOUR-REAL-OPENAI-API-KEY"


# === Optional: shared-password protection ===
#
# If you set APP_PASSWORD, users see a password screen before they can use
# the app. Anyone who knows the password gets in.
#
# To DISABLE auth: leave the line below commented out (the default).
# To ENABLE auth:  uncomment the line and replace the value with a strong password.
#
# APP_PASSWORD = "change-me-to-a-strong-password"
